<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<svg
   width="32"
   height="32"
   viewBox="0 0 32 32"
   version="1.1"
   id="svg8"
   xmlns="http://www.w3.org/2000/svg">
  <g id="layer1">
    <!-- List / Document lines on the left representing the spreadsheet rows -->
    <!-- Bullet points -->
    <rect x="4" y="6" width="3" height="3" rx="0.5" fill="#000000" />
    <rect x="4" y="14" width="3" height="3" rx="0.5" fill="#000000" />
    <rect x="4" y="22" width="3" height="3" rx="0.5" fill="#000000" />
    
    <!-- Text row indicators -->
    <rect x="9" y="6.5" width="7" height="2" rx="0.5" fill="#000000" />
    <rect x="9" y="14.5" width="7" height="2" rx="0.5" fill="#000000" />
    <rect x="9" y="22.5" width="7" height="2" rx="0.5" fill="#000000" />

    <!-- Greek Sigma Symbol Σ on the right representing sum/summary/quantities -->
    <path
       fill="#000000"
       d="M 18,6 L 29,6 L 29,9.5 L 22.5,9.5 L 26.5,15.5 L 22.5,21.5 L 29,21.5 L 29,25 L 18,25 L 18,22 L 23,15.5 L 18,9 Z"
       id="sigma" />
  </g>
</svg>
