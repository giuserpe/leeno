<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
  <!-- Grid background lines -->
  <rect x="5" y="4" width="1" height="16" fill="#F0F4E0" opacity="0.1" />
  <rect x="11" y="4" width="1" height="16" fill="#F0F4E0" opacity="0.1" />
  <rect x="17" y="4" width="1" height="16" fill="#F0F4E0" opacity="0.1" />
  <!-- Gantt bars (staggered tasks) all in Lime/Accent to follow Rule 9 -->
  <rect x="4" y="6" width="6" height="1.5" rx="0.4" fill="#AAD400" />
  <rect x="8" y="11" width="7" height="1.5" rx="0.4" fill="#AAD400" />
  <rect x="12" y="16" width="6" height="1.5" rx="0.4" fill="#AAD400" />
  <!-- Halo (Knockout) for Arrow -->
  <rect x="14.5" y="9.25" width="7" height="3.5" fill="#1A2010" />
  <path d="M17.5 7 L23 11 L17.5 15 Z" fill="#1A2010" />
  <!-- Export Arrow in Arancione Azione -->
  <rect x="15.5" y="10.25" width="5.5" height="1.5" fill="#FF4D2E" />
  <path d="M18.5 8 L21.5 11 L18.5 14 Z" fill="#FF4D2E" />
</svg>
