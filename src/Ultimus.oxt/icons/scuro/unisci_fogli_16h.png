<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
  <!-- Sheet 1 (Background left) -->
  <rect x="4" y="8" width="8" height="11" rx="0.4" fill="#808080" opacity="0.5" />
  <!-- Sheet 2 (Background right) -->
  <rect x="12" y="4" width="8" height="11" rx="0.4" fill="#808080" opacity="0.3" />
  <!-- Consolidated Front Sheet -->
  <!-- Outer border of front sheet -->
  <rect x="7" y="6" width="10" height="13" rx="0.4" fill="#F0F4E0" />
  <!-- Inner fill of front sheet -->
  <rect x="8.5" y="7.5" width="7" height="10" fill="#1A2010" />
  <!-- Halo (Knockout) for Merge Arrows -->
  <rect x="8" y="8.5" width="8.5" height="7.5" fill="#1A2010" />
  <!-- Merge Arrow -->
  <rect x="9" y="11.5" width="5" height="1.5" fill="#AAD400" />
  <path d="M12.5 9.5 L15.5 12.25 L12.5 15 Z" fill="#AAD400" />
</svg>
